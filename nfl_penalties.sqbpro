<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="nfl_penalties.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="3"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="2363"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="nfl_penalties_32_teams" custom_title="0" dock_id="1" table="4,22:mainnfl_penalties_32_teams"/><dock_state state="000000ff00000000fd00000001000000020000000000000000fc0100000001fb000000160064006f0063006b00420072006f00770073006500310100000000ffffffff0000011800ffffff000000000000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings/></tab_browse><tab_sql><sql name="Net Penalty Differential by Team.sql*" filename="C:/Users/bryce/Desktop/Data Projects/NFL Penalties Project/SQL Code/Net Penalty Differential by Team.sql">-- Reference to file &quot;C:/Users/bryce/Desktop/Data Projects/NFL Penalties Project/SQL Code/Net Penalty Differential by Team.sql&quot; (not supported by this version) --</sql><sql name=" Season by Season Trend per Team">SELECT
    Season,
    Team,
    &quot;Against Count&quot;,
    &quot;Beneficiary Count&quot;,
    &quot;Net Count&quot;,
    &quot;Net Yards&quot;
FROM nfl_penalties_32_teams
ORDER BY Team, Season;</sql><sql name="Lions Spotlight">SELECT
    Season,
    Team,
    &quot;Against Count&quot;,
    &quot;Against Yards&quot;,
    &quot;Beneficiary Count&quot;,
    &quot;Net Count&quot;,
    &quot;Net Yards&quot;
FROM nfl_penalties_32_teams
WHERE Team = 'Detroit'
ORDER BY Season;</sql><sql name="High Leverage Penalties">SELECT
    season,
    penalty_team,
    penalty_type,
    COUNT(*) AS penalty_count,
    SUM(penalty_yards) AS total_yards
FROM play_by_play_combined
WHERE qtr = 4
    AND ABS(score_differential) &lt;= 8
    AND penalty = 1.0
GROUP BY season, penalty_team, penalty_type
ORDER BY penalty_count DESC;</sql><sql name="Most Common Penalty Types per Team*">SELECT
    CASE 
        WHEN penalty_team = 'OAK' THEN 'LV'
        WHEN penalty_team = 'SD' THEN 'LAC'
        ELSE penalty_team
    END AS penalty_team,
    penalty_type,
    COUNT(*) AS total_calls,
    SUM(penalty_yards) AS total_yards
FROM play_by_play_combined
WHERE penalty = 1.0
    AND penalty_type IN (
        'Defensive Pass Interference',
        'Defensive Holding',
        'Offensive Holding',
        'Roughing the Passer',
        'False Start',
        'Unnecessary Roughness'
    )
GROUP BY penalty_team, penalty_type
ORDER BY penalty_team, total_calls DESC;</sql><sql name="Home vs Away Differential">SELECT
    Team,
    SUM(Home) AS &quot;Home Penalties&quot;,
    SUM(Away) AS &quot;Away Penalties&quot;,
    SUM(Home) - SUM(Away) AS &quot;Home Away Diff&quot;
FROM nfl_penalties_32_teams
GROUP BY Team
ORDER BY SUM(Home) - SUM(Away) DESC;

SELECT
    Team,
    SUM(Home) AS &quot;Home Penalties&quot;,
    SUM(Away) AS &quot;Away Penalties&quot;,
    SUM(Home) - SUM(Away) AS &quot;Home Away Diff&quot;
FROM nfl_penalties_32_teams
GROUP BY Team
ORDER BY SUM(Home) - SUM(Away) DESC;</sql><sql name="SQL 8">SELECT
    Team,
    Home AS &quot;Home Penalties&quot;,
    Away AS &quot;Away Penalties&quot;,
    (Home - Away) AS &quot;Home Away Diff&quot;
FROM nfl_penalties_32_teams
GROUP BY Team
ORDER BY (Home - Away) DESC;</sql><current_tab id="4"/></tab_sql></sqlb_project>
